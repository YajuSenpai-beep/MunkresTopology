\titleformat{name=\section,numberless}
  {\normalfont\large\bfseries}
  {}
  {0pt}
  {}
\titlespacing{name=\section,numberless}{0pt}{2em}{1em}
\makeatletter
\let\orig@star@section\section
\def\section{\@ifstar{\@star@section}{\orig@star@section}}
\def\@star@section#1{%
  \in@{§}{#1}%
  \ifin@
    \stepcounter{section}%
    \noexpandarg\StrBehind{#1}{ }[\sectiontmp]%
    \expandarg
    \StrBefore{\sectiontmp}{ }[\secnum]%
    \StrBehind{\sectiontmp}{ }[\sectionname]%
    \noexpandarg
    \in@{*}{#1}%
    \ifin@
      \noexpandarg\StrDel{#1}{*}[\cleanarg]%
      \orig@star@section*{\raisebox{0.15ex}{\small *}\cleanarg}%
      \phantomsection
      \addcontentsline{toc}{section}{\llap{\raisebox{0.15ex}{\small *}}\secnum\quad\sectionname}%
    \else
      \orig@star@section*{#1}%
      \phantomsection
      \addcontentsline{toc}{section}{\secnum\quad\sectionname}%
    \fi
    \markright{\sectionname}%
  \else
    \in@{*}{#1}%
    \ifin@
      \noexpandarg\StrBehind{#1}{ }[\sectiontitle]%
      \orig@star@section*{\raisebox{0.15ex}{\small *}\ \sectiontitle}%
      \phantomsection
      \addcontentsline{toc}{section}{\llap{\raisebox{0.15ex}{\small *}}\sectiontitle}%
      \markright{\sectiontitle}%
    \else
      \orig@star@section*{#1}%
    \fi
  \fi
}
\makeatother
