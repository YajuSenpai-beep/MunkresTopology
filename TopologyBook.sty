% ---------- 目录 ----------
\setcounter{tocdepth}{1}
\makeatletter
% All chapters: "Chapter N. Title ...... page" + dot leaders
\renewcommand*\l@chapter[2]{%
  \ifnum \c@tocdepth >\m@ne
    \addpenalty{-\@highpenalty}%
    \vskip 1.0em \@plus\p@
    \begingroup
      \parindent \z@ \rightskip \@pnumwidth
      \parfillskip -\@pnumwidth
      \leavevmode\large\bfseries
      \def\numberline##1{\chaptername~##1\ }%
      #1\nobreak
      \leaders\hbox{$\m@th\mkern \@dotsep mu\hbox{.}\mkern \@dotsep mu$}\hfill
      \hb@xt@\@pnumwidth{\hfil\bfseries #2}\par
      \penalty\@highpenalty
    \endgroup
  \fi}
% Part: "Part I Title" without page number (after titlesec init)
\AddToHook{begindocument/end}{%
  \renewcommand*\l@part[2]{%
    \ifnum \c@tocdepth >-2\relax
      \addpenalty{-\@highpenalty}%
      \vskip 0.5em \@plus\p@
      \begingroup
        \parindent \z@
        {\leavevmode\Large\bfseries\partname~\MakeUppercase{#1}\par}%
        \nobreak
        \vskip 0.3em \@plus\p@
      \endgroup
    \fi}%
  % Section: "N. Title ...... page" + dot leaders, one size larger
  \renewcommand*\l@section[2]{%
    \ifnum \c@tocdepth >\z@
      \addpenalty{-\@highpenalty}%
      \vskip 0.1em \@plus\p@
      \begingroup
        \parindent \z@ \rightskip \@pnumwidth
        \parfillskip -\@pnumwidth
        \leavevmode\large
        \hskip 1.5em #1\nobreak
        \leaders\hbox{$\m@th\mkern \@dotsep mu\hbox{.}\mkern \@dotsep mu$}\hfill
        \hb@xt@\@pnumwidth{\hfil #2}\par
      \endgroup
    \fi}%
}
\makeatother

% ---------- 字体选项（保留键值选择）----------
\long\def\IfFontTimesTF#1#2{#2}
\ExplSyntaxOn
\keys_define:nn { TopologyBook / option }{
  font          .choice:,
  font / times  .code:n = {
    \ifxetex
      \setmainfont{Times New Roman}[
        BoldFont       = Times New Roman Bold,
        ItalicFont     = Times New Roman Italic,
        BoldItalicFont = Times New Roman Bold Italic
      ]
      % 若系统无 Times New Roman，可改用 TeX Gyre Termes
      % \setmainfont{TeX Gyre Termes}[
      %   UprightFont    = *-Regular,
      %   BoldFont       = *-Bold,
      %   ItalicFont     = *-Italic,
      %   BoldItalicFont = *-BoldItalic
      % ]
    \else
      \PackageWarning{TopologyBook}{Times font requires XeLaTeX; falling back to default}
    \fi
    \long\def\IfFontTimesTF##1##2{##1}
    \DeclareTextFontCommand{\textsl}{\itshape}
    \renewcommand{\slshape}{\itshape}
  },
  font / euler  .code:n = {
    \usepackage[OT1]{eulervm}
    \DeclareSymbolFont{cmmlargesymbols}{OMX}{cmex}{m}{n}
    \DeclareSymbolFont{greekletters}{OML}{cmm}{m}{it}
    \DeclareMathDelimiter{\Newint}{\mathop}{cmmlargesymbols}{"52}{cmmlargesymbols}{"5A}
    \AddToHook{begindocument}{
      \renewcommand{\int}{\Newint\nolimits}
      \DeclareMathSymbol{\kappa}{\mathord}{greekletters}{"14}  
      \DeclareMathSymbol{\tau}{\mathord}{greekletters}{"1C}
      \DeclareMathSymbol{\omega}{\mathord}{greekletters}{"21}
    }
  },
  font / ncmr     .code:n = {
    \usepackage[default]{fontsetup}
  },
  font / cmr      .code:n = { },
  font / unknown  .code:n = {
    \msg_warning:nnn {TopologyBook} {unknown-font-option, use CMR instead.} {#1}
  },
}
\ProcessKeyOptions[ TopologyBook / option ]
\ExplSyntaxOff

