{
    "version": "1.0.0",
    "description": "Production-ready LaTeX index insertion tool",
    "homepage": "https://github.com/user/latex-index-tool",
    "license": "MIT",
    "depends": [
        "python"
    ],
    "bin": [
        ["latex-index"]
    ],
    "installer": {
        "script": [
            "pip install latex-index-tool"
        ]
    },
    "uninstaller": {
        "script": [
            "pip uninstall -y latex-index-tool"
        ]
    },
    "checkver": {
        "github": "https://github.com/user/latex-index-tool"
    },
    "autoupdate": {
        "url": "https://github.com/user/latex-index-tool/releases/tag/v$version"
    }
}
